---
interface Props {
  currentDate?: string;
  latestDate?: string;
  availableDates?: Array<{ date: string; productCount: number | null }>;
}

const { currentDate, latestDate, availableDates = [] } = Astro.props;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { month: 'long', day: 'numeric', year: 'numeric' });
}

function getDatePath(date: string): string {
  return `/producthunt/${date}`;
}

const today = new Date().toISOString().split('T')[0];
const isToday = currentDate === today;
---

<nav class="sticky top-0 z-50 backdrop-blur-xl bg-base-100/80 border-b border-base-300">
  <div class="container mx-auto px-4">
    <div class="navbar min-h-16">
      <div class="navbar-start">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-ph-orange hover:opacity-80 transition-opacity">
          <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="14" fill="#FF6154"/>
            <path d="M10 16C10 16 12 12 16 12C20 12 22 16 22 16C22 16 20 20 16 20C12 20 10 16 10 16Z" fill="white"/>
            <circle cx="16" cy="16" r="3" fill="#FF6154"/>
          </svg>
          <span class="hidden sm:inline">Product Hunt 精选</span>
        </a>
      </div>

      <div class="navbar-center">
        {latestDate && (
          <div class="flex items-center gap-2 text-sm">
            <a
              href={getDatePath(latestDate)}
              class:list={[
                'px-3 py-1.5 rounded-lg transition-all',
                currentDate === latestDate ? 'bg-ph-orange text-white' : 'hover:bg-base-300'
              ]}
            >
              最新
            </a>

            {availableDates.length > 0 && (
              <div class="dropdown dropdown-hover">
                <label tabindex="0" class="btn btn-ghost btn-sm gap-1">
                  <span>{currentDate ? formatDate(currentDate) : '选择日期'}</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </label>
                <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-200 rounded-box w-52 max-h-64 overflow-y-auto">
                  {availableDates.map(({ date, productCount }) => (
                    <li>
                      <a
                        href={getDatePath(date)}
                        class:list={[
                          currentDate === date && 'active'
                        ]}
                      >
                        <span>{formatDate(date)}</span>
                        <span class="badge badge-ghost badge-sm">{productCount ?? '?'}款</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {isToday && (
              <span class="badge badge-primary badge-outline">今日</span>
            )}
          </div>
        )}
      </div>

      <div class="navbar-end">
        <a
          href="https://www.producthunt.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost btn-sm"
        >
          PH官网
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>
