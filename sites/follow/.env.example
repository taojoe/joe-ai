# Cloudflare Credentials
# Find Account ID in Dashboard URL after /dash/
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Create API Token with D1:Edit and R2:Edit permissions
CLOUDFLARE_API_TOKEN=your_api_token_here

# D1 Database ID (bfd0d75c-3f43-4e4a-8f5c-8a8b8c8d8e8f)
D1_DATABASE_ID=bfd0d75c-3f43-4e4a-8f5c-8a8b8c8d8e8f

# R2 Bucket Name (follow-assets)
R2_BUCKET_NAME=follow-assets
