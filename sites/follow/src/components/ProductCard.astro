---
interface Props {
  product: {
    id: string;
    rank: number;
    slug: string;
    title: string;
    taglineZh: string | null;
    votes: number | null;
    url: string | null;
    website: string | null;
    topicsZh: string | null;
    isAi: boolean | null;
    thumbnail: string | null;
    descriptionHtml: string | null;
  };
  imageBaseUrl: string;
  index: number;
}

const { product, imageBaseUrl, index } = Astro.props;

const rankEmoji = product.rank === 1 ? '🥇' : product.rank === 2 ? '🥈' : product.rank === 3 ? '🥉' : `#${product.rank}`;
const rankClass = product.rank === 1 ? 'from-amber-500 to-orange-500' : product.rank === 2 ? 'from-gray-300 to-gray-500' : product.rank === 3 ? 'from-amber-700 to-amber-900' : '';

const topics: string[] = product.topicsZh ? JSON.parse(product.topicsZh) : [];
const thumbnailUrl = product.thumbnail
  ? `${imageBaseUrl}/${product.thumbnail}`
  : null;
---

<article
  class:list={[
    'group relative bg-white/5 backdrop-blur-xl rounded-2xl overflow-hidden',
    'border border-white/10 hover:border-ph-orange/50',
    'transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-ph-orange/10',
    'animate-fade-in-up'
  ]}
  style={`animation-delay: ${index * 80}ms`}
>
  {product.rank <= 3 && (
    <div class:list={[
      'absolute top-0 left-0 right-0 h-1 bg-gradient-to-r',
      rankClass
    ]} />
  )}

  <div class="p-4">
    {thumbnailUrl && (
      <div class="relative aspect-video mb-4 rounded-xl overflow-hidden bg-base-300">
        <img
          src={thumbnailUrl}
          alt={product.title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
        {product.isAi && (
          <span class="absolute top-2 right-2 badge badge-primary badge-sm">AI</span>
        )}
      </div>
    )}

    <div class="flex items-start justify-between gap-2 mb-2">
      <span class="text-2xl">{rankEmoji}</span>
      <h3 class="text-lg font-bold text-gray-100 group-hover:text-ph-orange transition-colors line-clamp-1">
        {product.title}
      </h3>
    </div>

    {product.taglineZh && (
      <p class="text-gray-400 text-sm mb-3 line-clamp-2">
        {product.taglineZh}
      </p>
    )}

    <div class="flex flex-wrap gap-1 mb-3">
      {topics.slice(0, 3).map((topic) => (
        <span class="badge badge-ghost badge-sm">{topic}</span>
      ))}
    </div>

    {product.descriptionHtml && (
      <div class="text-gray-300 text-sm mb-4 prose prose-sm prose-invert max-w-none line-clamp-3" set:html={product.descriptionHtml} />
    )}

    <div class="flex items-center justify-between pt-3 border-t border-white/5">
      {product.votes && (
        <div class="flex items-center gap-1 text-ph-orange">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span class="font-bold">{product.votes.toLocaleString()}</span>
          <span class="text-gray-500 text-xs">票</span>
        </div>
      )}

      <div class="flex gap-2">
        {product.website && (
          <a
            href={product.website}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost btn-xs gap-1"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
            官网
          </a>
        )}
        {product.url && (
          <a
            href={product.url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost btn-xs gap-1"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            PH
          </a>
        )}
      </div>
    </div>
  </div>
</article>
