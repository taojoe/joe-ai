{
  "name": "mseries-follow",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "prepare-db": "tsx scripts/prepare.ts",
    "upload:local": "tsx scripts/upload-local.ts",
    "upload:remote": "tsx --env-file=.env scripts/upload-remote.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply follow-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply follow-db --remote",
    "db:clean:local": "rm -rf .wrangler/state/v3/d1",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "cf-typegen": "wrangler types",
    "deploy": "astro build && wrangler deploy"
  },
  "dependencies": {
    "astro": "^6.1.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@aws-sdk/client-s3": "^3.1022.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.5.0",
    "cloudflare": "^5.2.0",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  }
}